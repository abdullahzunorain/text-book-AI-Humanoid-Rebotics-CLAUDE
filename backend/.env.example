# Backend environment variables
# Copy this file to .env and fill in your values

# --- Google Gemini (Primary LLM + Embeddings) ---
GEMINI_API_KEY=your-google-ai-studio-api-key-here
# Also needed by translation & personalization services (same key, different var name)
GOOGLE_API_KEY=your-google-api-key-here

# --- Groq (Failover LLM #2) ---
GROQ_API_KEY=your-groq-api-key-here

# --- OpenAI (Failover LLM #3) ---
OPENAI_API_KEY=your-openai-api-key-here

# --- Qdrant Cloud (Vector Database for RAG) ---
QDRANT_URL=https://your-cluster.us-east4-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key-here

# --- Neon Postgres (Auth, Cache, Chat History) ---
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# --- Application Configuration ---
APP_ENV=development
JWT_SECRET=your-jwt-secret-here

# --- CORS Origins (comma-separated) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- LLM Client Configuration (optional, with defaults) ---
# LLM_MAX_RETRIES=5
# LLM_BACKOFF_BASE=7
# LLM_BACKOFF_INITIAL=1
# LLM_BACKOFF_MAX=60
